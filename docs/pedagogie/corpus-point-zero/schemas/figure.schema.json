{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FigureProfile",
  "type": "object",
  "required": [
    "id",
    "name",
    "figure_type",
    "phase_label",
    "power_profiles"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "figure_type": {
      "enum": [
        "historique",
        "contemporaine",
        "fictionnelle",
        "mythologique",
        "spirituelle",
        "composite"
      ]
    },
    "phase_label": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "power_profiles": {
      "type": "array",
      "items": {
        "$ref": "motor_profile.schema.json"
      }
    },
    "manifested_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "shadows_and_costs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "last_reviewed_at": {
      "type": "string",
      "format": "date"
    }
  }
}
